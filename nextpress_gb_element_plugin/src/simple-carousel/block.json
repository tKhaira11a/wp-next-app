{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "nextpress-block/simple-carousel",
	"version": "0.1.0",
	"title": "Simple Carousel",
	"category": "nextpress-blocks",
	"description": "A Grid of styled, rectangle buttons.",
	"example": {},
	"attributes": {
		"cptId": {
			"type": "number"
		},
		"initialIndex": {
			"type": "number"
		},
		"instanceId": {
			"type": "string"
		},
		"slideIds": {
			"type": "array",
			"items": {
				"type": "number"
			}
		}
	},
	"supports": {
		"color": {
			"background": false,
			"text": true
		},
		"html": false,
		"typography": {
			"fontSize": true
		}
	},
	"textdomain": "simple-carousel-block",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./index.css"
}
