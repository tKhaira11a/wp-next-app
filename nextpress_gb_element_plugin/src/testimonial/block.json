{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "nextpress-block/testimonial",
	"version": "0.1.0",
	"title": "Testimonial",
	"parent": [ "nextpress-block/animated-testimonial", "nextpress-block/moving-cards"],
