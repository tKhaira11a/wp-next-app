# ============================================
# WordPress + Next.js Docker Environment
# ============================================
# Copy this file to .env and adjust values

# --------------------------------------------
# Database Configuration
# --------------------------------------------
DB_ROOT_PASSWORD=your_root_password_here
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=your_db_password_here
DB_PORT=3306

# --------------------------------------------
# WordPress Configuration
# --------------------------------------------
WP_PORT=8888
WP_TABLE_PREFIX=wp_

# WordPress Admin Account
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=your_admin_password_here
WP_ADMIN_EMAIL=admin@yourdomain.com
WP_SITE_TITLE="My Headless WordPress"
WP_SITE_URL=http://localhost:8888
WP_HOSTNAME=localhost

# --------------------------------------------
# Headless Configuration
# --------------------------------------------
# Leave empty to auto-generate
HEADLESS_SECRET=
GRAPHQL_JWT_SECRET=

# URL where Next.js will run
HEADLESS_URL=http://localhost:3000

# --------------------------------------------
# App User Configuration (for Next.js API access)
# --------------------------------------------
APP_USER_NAME=NextApp-User
APP_USER_EMAIL=nextapp@yourdomain.com
APP_USER_PASSWORD=your_app_user_password_here

# --------------------------------------------
# Next.js Configuration
# --------------------------------------------
NEXTJS_PORT=3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Resend API Key for email functionality
# Get your key at: https://resend.com
RESEND_API_KEY=

# These will be auto-generated during setup:
# WP_APP_PASS (Application Password)
# NOT_FOUND_ID (404 Page ID)

# --------------------------------------------
# Host User Configuration (for file permissions)
# --------------------------------------------
HOST_UID=1000
HOST_GID=1000
