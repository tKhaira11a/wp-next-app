{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "nextpress-form-block/select",
	"version": "1.0.0",
	"title": "Select",
	"category": "nextpress-form-blocks",
	"description": "Select-Control",
	"example": {},
	"attributes": {
		"cptId": {
			"type": "number"
		},
		"label": {
			"type": "string"
		},
		"instanceId": {
			"type": "string"
		},
		"fieldName": {
			"type": "string"
		},
		"selectValues": {
			"type": "array",
			"items": {
				"type": "object"
			},
			"default": [
				{
					"label":"",
					"value":""
				}
			]
		}
	},
	"supports": {
		"color": {
			"background": false,
			"text": true
		},
		"html": false,
		"typography": {
			"fontSize": true
		}
	},
	"textdomain": "select-block",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
